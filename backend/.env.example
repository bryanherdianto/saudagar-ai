# ============================================================
# Saudagar.ai — Backend environment variables
# Copy this file to `.env` and fill in your values.
# ============================================================

# --- Google Gemini (LangChain) ---
# Get a key at https://aistudio.google.com/app/apikey
# Leave EMPTY to run in "mock mode" (deterministic rule-based responses,
# no API calls) so you can develop the UI without a key.
GEMINI_API_KEY=

# Chat model used by the assistant, insights, catalog and CS features.
GEMINI_MODEL=gemini-2.5-flash

# Embedding model used for RAG retrieval over the store catalog.
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# Sampling temperature for the chat model (0.0 = deterministic).
LLM_TEMPERATURE=0.3

# --- Database ---
# Defaults to a local SQLite file; no setup required.
# For Postgres: postgresql+psycopg://user:pass@localhost:5432/saudagar
DATABASE_URL=sqlite:///./saudagar.db

# --- CORS ---
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- App ---
ENVIRONMENT=development
