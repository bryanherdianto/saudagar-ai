# ============================================================
# Saudagar.ai - Frontend environment variables
# Copy this file to `.env.local` and adjust if needed.
# ============================================================

# Base URL of the FastAPI backend. Must be reachable from the browser,
# so it is exposed to the client via the NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Clerk
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
